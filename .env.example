# OpenRouter (OpenAI-compatible endpoint) — один ключ, много моделей
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Main agent — нужен vision + tool calling.
# Options that pass smoke + safety:
#   google/gemini-2.5-flash    (free tier, vision, recommended default)
#   openai/gpt-4o-mini         (paid, cheap, OpenAI)
#   openai/gpt-5-mini          (paid, stronger reasoning, escalation)
MODEL=google/gemini-2.5-flash

DOM_MODEL=openai/gpt-oss-20b:free

# Опции запуска
# BROWSER_CHANNEL=chrome 
# HEADLESS=1               
# PERSISTENT=1             
# VIDEO=0                 
